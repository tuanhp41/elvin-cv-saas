{
  "plugins": ["import"],
  "rules": {
    "import/no-cycle": ["error", { "maxDepth": 99 }],
    "import/order": ["warn", {
      "groups": ["builtin", "external", "internal"],
      "newlines-between": "always"
    }],
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "warn"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  }
}
